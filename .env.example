# AgentHub 环境变量配置
# 复制此文件为 .env 并修改

# ===== 安全配置（P1 - 生产环境必须修改） =====

# JWT 签名密钥 - 生产环境必须修改为随机字符串
# 生成方式: openssl rand -hex 32
JWT_SECRET=change-me-in-production-use-random-32-chars

# 加密密钥（独立于 JWT_SECRET） - 用于加密存储的 API 密钥
# 生成方式: openssl rand -base64 32
ENCRYPTION_KEY=change-me-in-production-use-random-base64-32-bytes

# API Server 密钥（用于 Docker Secrets）
# 生成方式: openssl rand -hex 32
API_SERVER_KEY=change-me

# CORS 允许的来源（严格限制，不能使用通配符）
CORS_ORIGINS=http://localhost

# 环境标识（production 或 development）
ENVIRONMENT=development

# ===== 可选配置 =====

# 后端端口
BACKEND_PORT=8000

# 前端端口（Docker Compose 模式下的外部映射端口）
FRONTEND_PORT=80

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Hermes 实例端口范围
PORT_RANGE_START=9001
PORT_RANGE_END=9100

# 数据库 URL（默认使用 SQLite）
DATABASE_URL=sqlite+aiosqlite:///./data/agenthub.db
